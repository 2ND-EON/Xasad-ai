# =====================================
# XASAD REPOSITORY ENVIRONMENT CONFIGURATION TEMPLATE
# =====================================
# Copy this file to a local '.env' file for development.
# For production, bind these keys in your CloudFlare Dashboard settings.

# Public Frontend Client Injection Variables
VITE_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE
VITE_PAYPAL_PLAN_STANDARD=P-YOUR_STANDARD_PLAN_ID
VITE_PAYPAL_PLAN_PRO=P-YOUR_PRO_PLAN_ID
VITE_API_BASE_URL=https://xasad-brain.YOUR_SUBDOMAIN.workers.dev

# Secure Private Backend Variables (CloudFlare Environment Secrets)
PAYPAL_SECRET_KEY=YOUR_PAYPAL_SECRET_KEY_HERE
